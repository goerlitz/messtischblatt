{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "autoAllowBashIfSandboxed": false,
    "filesystem": {
      "denyRead": [
        "~/"
      ],
      "allowRead": [
        "."
      ],
      "denyWrite": [
        "~/"
      ],
      "allowWrite": [
        "."
      ]
    }
  },
  "permissions": {
    "allow": [
      "Read(./**)",
      "LS(./**)",
      "Glob(./**)",
      "Grep(./**)"
    ],
    "ask": [
      "Edit(./**)",
      "Write(./**)",
      "MultiEdit(./**)",
      "Bash(*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./secrets/**)",

      "Grep(./.env)",
      "Grep(./.env.*)",
      "Grep(./**/.env)",
      "Grep(./**/.env.*)",
      "Grep(./secrets/**)"
    ]
  }
}

